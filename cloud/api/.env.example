# 复制为 .env 并填写真实值

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=esplink
DB_PASSWORD=esplink123
DB_NAME=esplink

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT 签名密钥（生产环境必须换成随机长字符串）
SECRET_KEY=change-me-in-production-use-random-32-chars

# 微信小程序（填入自己的 AppID 和 Secret）
WX_APPID=
WX_SECRET=

# 返回给设备的 WebSocket 地址（设备用这个地址连接）
WS_BASE_URL=ws://localhost:8000

# 调试模式（开发时设 true，生产设 false）
DEBUG=true
