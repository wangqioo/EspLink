.container { padding: 40rpx 32rpx; min-height: 100vh; }

.header { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0 48rpx; }
.header-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.header-title { font-size: 40rpx; font-weight: 600; color: #1a1a2e; margin-bottom: 12rpx; }
.header-sub { font-size: 26rpx; color: #888; text-align: center; }

.scan-bar {
  display: flex; align-items: center; padding: 24rpx 32rpx;
  background: #fff; border-radius: 20rpx; margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.scan-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: #ccc; margin-right: 16rpx; flex-shrink: 0;
}
.scan-dot.scanning { background: #4CAF50; animation: pulse 1.2s infinite; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
.scan-text { flex: 1; font-size: 28rpx; color: #555; }
.btn-rescan {
  font-size: 26rpx; color: #1a73e8; background: none;
  border: none; padding: 0; margin: 0; line-height: 1;
}

.device-list { background: #fff; border-radius: 20rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.device-item { display: flex; align-items: center; padding: 32rpx 28rpx; border-bottom: 1rpx solid #f0f0f0; }
.device-item:last-child { border-bottom: none; }
.device-icon { font-size: 48rpx; margin-right: 24rpx; }
.device-info { flex: 1; }
.device-name { display: block; font-size: 32rpx; color: #1a1a2e; font-weight: 500; }
.device-rssi { display: block; font-size: 24rpx; color: #999; margin-top: 6rpx; }
.device-arrow { font-size: 40rpx; color: #ccc; }

.empty, .loading { text-align: center; padding: 80rpx 0; }
.empty-text { display: block; font-size: 32rpx; color: #555; margin-bottom: 16rpx; }
.empty-sub  { display: block; font-size: 24rpx; color: #aaa; }
.loading-text { font-size: 28rpx; color: #999; }
