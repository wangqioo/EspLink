.container { padding: 32rpx; min-height: 100vh; background: #f5f6fa; }

.status-card {
  background: #1a1a2e; border-radius: 24rpx; padding: 48rpx 40rpx;
  display: flex; flex-direction: column; align-items: center;
  margin-bottom: 28rpx;
}
.device-icon { font-size: 96rpx; margin-bottom: 20rpx; }
.status-dot {
  width: 20rpx; height: 20rpx; border-radius: 50%; margin-bottom: 12rpx;
}
.status-dot.online  { background: #4CAF50; box-shadow: 0 0 12rpx #4CAF50; }
.status-dot.offline { background: #666; }
.status-label { font-size: 28rpx; color: #aaa; margin-bottom: 8rpx; }
.board-type   { font-size: 32rpx; color: #fff; font-weight: 600; margin-bottom: 8rpx; }
.fw-ver       { font-size: 24rpx; color: #666; }

.info-section {
  background: #fff; border-radius: 20rpx; padding: 8rpx 32rpx;
  margin-bottom: 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.info-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.info-row:last-child { border-bottom: none; }
.info-key { font-size: 28rpx; color: #888; }
.info-val  { font-size: 28rpx; color: #1a1a2e; }
.mono { font-family: monospace; font-size: 26rpx; }

.btn-feature {
  width: 100%; background: #1a73e8; color: #fff;
  border-radius: 20rpx; font-size: 32rpx; padding: 32rpx 0; border: none;
}

.loading { text-align: center; padding: 120rpx 0; font-size: 28rpx; color: #999; }
