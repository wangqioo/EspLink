<view class="container" wx:if="{{!loading && device}}">

  <!-- 状态卡片 -->
  <view class="status-card">
    <view class="device-icon">📦</view>
    <view class="status-dot {{device.is_online ? 'online' : 'offline'}}"></view>
    <text class="status-label">{{device.is_online ? '在线' : '离线'}}</text>
    <text class="board-type">{{device.board_type}}</text>
    <text class="fw-ver">固件 {{device.firmware_version || '-'}}</text>
  </view>

  <!-- 基本信息 -->
  <view class="info-section">
    <view class="info-row">
      <text class="info-key">设备名称</text>
      <text class="info-val">{{device.alias || device.board_type}}</text>
    </view>
    <view class="info-row">
      <text class="info-key">MAC 地址</text>
      <text class="info-val mono">{{device.mac}}</text>
    </view>
    <view class="info-row" wx:if="{{device.last_seen_at}}">
      <text class="info-key">最后上线</text>
      <text class="info-val">{{device.last_seen_at}}</text>
    </view>
  </view>

  <!-- 功能入口 -->
  <button class="btn-feature" bindtap="onOpenFeaturePage">
    打开设备功能页
  </button>

</view>

<view class="loading" wx:elif="{{loading}}">
  <text>加载中...</text>
</view>
