.container { padding: 32rpx; min-height: 100vh; }

.device-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.device-icon { font-size: 56rpx; margin-right: 24rpx; }
.device-name { display: block; font-size: 32rpx; font-weight: 600; color: #1a1a2e; }
.device-id   { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }

/* 步骤条 */
.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}
.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 22rpx;
  color: #bbb;
}
.step.active .step-dot { background: #1a73e8; color: #fff; }
.step.done   .step-dot { background: #4CAF50; color: #fff; }
.step-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #eee;
  color: #bbb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-bottom: 8rpx;
  font-weight: 600;
}
.step-line { flex: 1; height: 2rpx; background: #eee; margin: 0 8rpx 20rpx; }

/* 表单 */
.form {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.form-item {
  margin-bottom: 32rpx;
  position: relative;
}
.form-label {
  display: block;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 12rpx;
}
.form-input {
  width: 100%;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #1a1a2e;
  box-sizing: border-box;
}
.input-wrap {
  position: relative;
}
.input-wrap .form-input {
  padding-right: 100rpx;
}
.toggle-pw {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 26rpx;
  color: #1a73e8;
  white-space: nowrap;
}
.btn-primary {
  width: 100%;
  margin-top: 8rpx;
  background: #1a73e8;
  color: #fff;
  border-radius: 20rpx;
  font-size: 32rpx;
  padding: 28rpx 0;
  border: none;
}
.btn-primary[disabled] { background: #b0c8f5; }

/* 进度 */
.progress {
  text-align: center;
  padding: 80rpx 0;
}
.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #1a73e8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 32rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.progress-text { display: block; font-size: 32rpx; color: #1a1a2e; margin-bottom: 12rpx; }
.progress-sub  { display: block; font-size: 26rpx; color: #999; }

/* 错误 */
.error-card {
  background: #fff3f3;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-top: 32rpx;
  text-align: center;
}
.error-text { display: block; font-size: 28rpx; color: #e53935; margin-bottom: 24rpx; }
.btn-retry {
  font-size: 28rpx;
  color: #e53935;
  background: none;
  border: 1rpx solid #e53935;
  border-radius: 16rpx;
  padding: 16rpx 48rpx;
}
