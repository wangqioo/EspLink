<view class="container">

  <!-- 顶部 -->
  <view class="header">
    <text class="header-title">我的设备</text>
    <view class="btn-add" bindtap="onAddDevice">+</view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 设备列表 -->
  <scroll-view
    wx:elif="{{devices.length > 0}}"
    scroll-y
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    class="device-list"
  >
    <view
      class="device-card"
      wx:for="{{devices}}"
      wx:key="id"
      bindtap="onTapDevice"
      data-device="{{item}}"
    >
      <view class="card-left">
        <view class="device-icon">📦</view>
        <view class="device-info">
          <text class="device-name">{{item.alias || item.board_type}}</text>
          <text class="device-type">{{item.board_type}}</text>
        </view>
      </view>
      <view class="card-right">
        <view class="status-dot {{item.is_online ? 'online' : 'offline'}}"></view>
        <text class="status-text">{{item.is_online ? '在线' : '离线'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </scroll-view>

  <!-- 空状态 -->
  <view class="empty" wx:elif="{{!loading}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">还没有设备</text>
    <text class="empty-sub">点击右上角 + 添加第一台设备</text>
    <button class="btn-empty-add" bindtap="onAddDevice">添加设备</button>
  </view>

</view>
