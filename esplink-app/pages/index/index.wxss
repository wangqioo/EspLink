.container {
  padding: 0 0 40rpx;
  min-height: 100vh;
  background: #f5f6fa;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 48rpx 32rpx 32rpx;
  background: #1a1a2e;
}
.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}
.btn-add {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #1a73e8;
  color: #fff;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.loading {
  text-align: center;
  padding: 120rpx 0;
}
.loading-text { font-size: 28rpx; color: #999; }

.device-list {
  padding: 24rpx 24rpx 0;
  height: calc(100vh - 160rpx);
}

.device-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.card-left {
  display: flex;
  align-items: center;
  flex: 1;
}
.device-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}
.device-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}
.device-type {
  display: block;
  font-size: 24rpx;
  color: #999;
}
.card-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}
.status-dot.online  { background: #4CAF50; }
.status-dot.offline { background: #ccc; }
.status-text {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}
.arrow { font-size: 40rpx; color: #ccc; }

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 0;
}
.empty-icon { font-size: 120rpx; margin-bottom: 32rpx; }
.empty-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.empty-sub {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 64rpx;
}
.btn-empty-add {
  background: #1a73e8;
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  padding: 24rpx 80rpx;
  border: none;
}
