page {
  background: #f5f5f5;
  font-family: -apple-system, 'PingFang SC', sans-serif;
  box-sizing: border-box;
}

.btn-primary {
  background: #1a73e8;
  color: #fff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 24rpx 0;
  text-align: center;
  border: none;
}

.btn-primary[disabled] {
  background: #b0c8f5;
}
